span class="keyword">function</span> (<span class="params">content, &#123; cn = <span class="number">300</span>, en = <span class="number">160</span> &#125; = &#123;&#125;</span>) &#123;</span><br><span class="line">  <span class="keyword">var</span> len = <span class="title function_">counter</span>(content);</span><br><span class="line">  <span class="keyword">var</span> readingTime = len[<span class="number">0</span>] / cn + len[<span class="number">1</span>] / en;</span><br><span class="line">  <span class="keyword">return</span> readingTime &lt; <span class="number">1</span> ? <span class="string">&#x27;1&#x27;</span> : <span class="built_in">parseInt</span>(readingTime, <span class="number">10</span>) + <span class="string">&#x27; &#x27;</span>;</span><br><span class="line">&#125;);</span><br><span class="line"></span><br><span class="line">hexo.<span class="property">extend</span>.<span class="property">helper</span>.<span class="title function_">register</span>(<span class="string">&#x27;wordcount&#x27;</span>, <span class="keyword">function</span> (<span class="params">content</span>) &#123;</span><br><span class="line">  <span class="keyword">var</span> len = <span class="title function_">counter</span>(content);</span><br><span class="line">  <span class="keyword">var</span> count = len[<span class="number">0</span>] + len[<span class="number">1</span>];</span><br><span class="line">  <span class="keyword">if</span> (count &lt; <span class="number">1000</span>) &#123;</span><br><span class="line">    <span class="keyword">return</span> count;</span><br><span class="line">  &#125;</span><br><span class="line">  <span class="keyword">return</span> <span class="title class_">Math</span>.<span class="title function_">round</span>(count / <span class="number">100</span>) / <span class="number">10</span> + <span class="string">&#x27; k&#x27;</span>;</span><br><span class="line">&#125;);</span><br><span class="line"></span><br><span class="line">hexo.<span class