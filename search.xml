: <span class="built_in">parseInt</span>(readingTime, <span class="number">10</span>);</span><br><span class="line"><span class="keyword">return</span> readingTime &lt; <span class="number">1</span> ? <span class="string">&#x27;1&#x27;</span> : <span class="built_in">parseInt</span>(readingTime, <span class="number">10</span>) + <span class="string">&#x27; &#x27;</span>;</span><br><span class="line"></span><br><span class="line"><span class="keyword">return</span> <span class="title class_">Math</span>.<span class="title function_">round</span>(count / <span class="number">100</span>) / <span class="number">10</span> + <span class="string">&#x27;k&#x27;</span>;</span><br><span class="line"><span class="keyword">return</span> <span class="title class_">Math</span>.<span class="title function_">round</span>(count / <span class="number">100</span>) / <span class="number">10</span> + <span class="string">&#x27; k&#x27;</span>;</span><br><span class="line"></span><br><span class="line"><span class="keyword">return</span> <span class="title class_">Math</span>.<span class="title function_">round</span>(count / <span class="number">100</span>) / <span class="number">10</span> + <span class="string">&#x27;k&#x27;</span>;</span><br><span class="line"><span class="keyword">return</span> <span class="title class_">Math</span>.<span class="title function_">round</span>(count / <span class="number">100</span>) / <span class="number">10</span> + <span class="string">&#x27; k&#x27;</span>;</span><br></pre></td></tr></table></figure>]]></content>
      
      
